// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "allFeatures": true,
        },
        "check": {
          "command": "clippy",
        },
      },
    },
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "Local Qwen",
      "model": "Qwen_Qwen2.5-Coder-3B-Instruct-GGUF_qwen2.5-coder-3b-instruct-q4_k_m.gguf",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "language_models": {
    "openai_compatible": {
      "Local Qwen": {
        "api_url": "http://localhost:8080/v1",
        "available_models": [
          {
            "name": "Qwen_Qwen2.5-Coder-3B-Instruct-GGUF_qwen2.5-coder-3b-instruct-q4_k_m.gguf",
            "display_name": "Qwen2.5-Coder 3B",
            "max_tokens": 8192,
            "capabilities": {
              "tools": false,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "show_wrap_guides": true,
  "search": {
    "button": false,
  },
  "bottom_dock_layout": "contained",
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
    "show": true,
  },
  "tabs": {
    "activate_on_close": "left_neighbour",
    "close_position": "right",
    "file_icons": false,
    "git_status": false,
  },
  "title_bar": {
    "show_menus": false,
  },
  "status_bar": {
    "active_encoding_button": "non_utf8",
    "active_language_button": true,
  },
  "git_panel": {
    "dock": "left",
    "tree_view": false,
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "dock": "bottom",
  },
  "project_panel": {
    "dock": "left",
    "button": true,
    "git_status": true,
  },
  "soft_wrap": "editor_width",
  "minimap": {
    "show": "never",
  },
  "relative_line_numbers": "enabled",
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "double_click_in_multibuffer": "open",
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "never",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "vim_mode": true,
  "ui_font_size": 18.0,
  "buffer_font_size": 18.0,
  "theme": "One Dark",
}
